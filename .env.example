# ── Supabase ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key     # SERVER ONLY

# ── Paystack ───────────────────────────────────────────────
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxx               # client-safe
PAYSTACK_SECRET_KEY=sk_live_xxxx                    # SERVER ONLY

# ── Pinecone ───────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_key                  # SERVER ONLY
PINECONE_INDEX_NAME=dealmatch-properties

# ── Upstash Redis ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io      # SERVER ONLY
UPSTASH_REDIS_REST_TOKEN=your_upstash_token         # SERVER ONLY

# ── Google Maps ────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=AIza...                    # Restrict to your domain in GCP

# ── Sentry ─────────────────────────────────────────────────
VITE_SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ── PostHog ────────────────────────────────────────────────
VITE_POSTHOG_KEY=phc_xxxx
VITE_POSTHOG_HOST=https://app.posthog.com

# ── Resend (email via Supabase custom SMTP) ────────────────
# Configure in Supabase Dashboard → Authentication → SMTP Settings
# SMTP Host:     smtp.resend.com
# SMTP Port:     465
# SMTP User:     resend
# SMTP Password: your_resend_api_key
# From address:  noreply@yourdomain.com
RESEND_API_KEY=re_xxxx                              # For Supabase custom SMTP

# ── App ────────────────────────────────────────────────────
VITE_APP_URL=https://dealmatch-yvdm.vercel.app
